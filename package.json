{
  "name": "tradepilot-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "diagnose:supplier-search": "node scripts/diagnose-supplier-search.mjs",
    "diagnose:url-import": "tsx scripts/diagnose-url-import.ts",
    "test:url-provider-live": "tsx scripts/test-url-provider-live.ts",
    "cache:import-supplier-fixture": "tsx scripts/import-supplier-search-fixture.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@aws-sdk/client-s3": "3.1067.0",
    "@aws-sdk/s3-request-presigner": "3.1067.0",
    "argon2": "0.44.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.9",
    "prisma": "6.19.3",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
