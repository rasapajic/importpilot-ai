generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum OAuthProvider {
  GOOGLE
  MICROSOFT
}

enum AuditAction {
  AUTH_REGISTERED
  AUTH_LOGIN_SUCCEEDED
  AUTH_LOGIN_FAILED
  AUTH_LOGOUT
}

enum ProjectStatus {
  DRAFT
  COLLECTING_OFFERS
  ANALYZING
  READY
}

enum ProjectCompletionStatus {
  ACTIVE
  DECIDED
  COMPLETED
  ARCHIVED
}

enum ProjectOutcomeType {
  BOUGHT
  NEGOTIATED
  ABANDONED
  POSTPONED
}

enum RecommendationFeedbackVote {
  HELPFUL
  NOT_HELPFUL
}

enum FileProcessingStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum DocumentType {
  OFFER
  PROFORMA
  SHIPPING_QUOTE
  PRODUCT_IMAGE
  OTHER
}

enum ProcessingJobType {
  OCR_EXTRACTION
  AI_EXTRACTION
  PROJECT_ANALYSIS
}

enum ProcessingJobStatus {
  PENDING
  PROCESSING
  RETRY_SCHEDULED
  COMPLETED
  DEAD_LETTER
}

enum OfferExtractionStatus {
  PENDING
  EXTRACTED
  MANUAL
  REVIEWED
  FAILED
}

enum CalculationStatus {
  DRAFT
  CALCULATED
  NEEDS_REVIEW
}

enum RecommendationStatus {
  RECOMMENDED
  OK_WITH_RISK
  NEEDS_NEGOTIATION
  NOT_RECOMMENDED
}

enum ProjectDecisionStatus {
  READY_TO_BUY
  NEGOTIATE_FIRST
  NEED_MORE_OFFERS
  DO_NOT_BUY
}

enum NegotiationTone {
  FORMAL
  DIRECT
  FRIENDLY
}

enum NegotiationMessageStatus {
  PROPOSED
  SENT
}

enum NegotiationRequestType {
  LOWER_MOQ
  BETTER_PRICE
  CONFIRM_INCOTERM
  CONFIRM_SHIPPING
  REQUEST_SAMPLE
  FINAL_PROFORMA_INVOICE
}

enum ProjectActivityType {
  PROJECT_CREATED
  OFFER_ADDED
  LANDED_COST_CALCULATED
  ASSESSMENT_COMPLETED
  FINAL_DECISION_CREATED
  NEGOTIATION_MESSAGE_GENERATED
  NEGOTIATION_MESSAGE_SENT
  DOCUMENT_UPLOADED
  DOCUMENT_DELETED
  PROJECT_OUTCOME_RECORDED
  RECOMMENDATION_FEEDBACK_RECORDED
  PROJECT_COMPLETION_CHANGED
}

model User {
  id           String               @id @default(uuid()) @db.Uuid
  email        String               @unique @db.VarChar(320)
  passwordHash String?              @map("password_hash") @db.VarChar(255)
  name         String               @db.VarChar(120)
  memberships  OrganizationMember[]
  sessions     Session[]
  oauthAccounts OAuthAccount[]
  auditEvents  AuditEvent[]
  createdProjects ImportProject[] @relation("ProjectCreator")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  @@map("users")
}

model Organization {
  id        String               @id @default(uuid()) @db.Uuid
  name      String               @db.VarChar(160)
  members   OrganizationMember[]
  sessions  Session[]
  auditEvents AuditEvent[]
  projects  ImportProject[]
  uploadedFiles UploadedFile[]
  supplierOffers SupplierOffer[]
  costCalculations CostCalculation[]
  offerAssessments OfferAssessment[]
  projectDecisions ProjectDecision[]
  negotiationMessages NegotiationMessage[]
  projectActivities ProjectActivity[]
  projectOutcomes ProjectOutcome[]
  recommendationFeedback RecommendationFeedback[]
  projectCompletionHistory ProjectCompletionHistory[]
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  @@map("organizations")
}

model OrganizationMember {
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           OrganizationRole @default(MEMBER)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now()) @map("created_at")

  @@id([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Session {
  id                   String       @id @default(uuid()) @db.Uuid
  tokenHash            String       @unique @map("token_hash") @db.Char(64)
  userId               String       @map("user_id") @db.Uuid
  activeOrganizationId String       @map("active_organization_id") @db.Uuid
  expiresAt            DateTime     @map("expires_at")
  lastSeenAt           DateTime     @default(now()) @map("last_seen_at")
  ipAddress            String?      @map("ip_address") @db.VarChar(64)
  userAgent            String?      @map("user_agent") @db.VarChar(512)
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganization   Organization @relation(fields: [activeOrganizationId], references: [id], onDelete: Cascade)
  createdAt             DateTime     @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model OAuthAccount {
  id                String        @id @default(uuid()) @db.Uuid
  provider          OAuthProvider
  providerAccountId String        @map("provider_account_id") @db.VarChar(255)
  userId            String        @map("user_id") @db.Uuid
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now()) @map("created_at")

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model AuditEvent {
  id             String        @id @default(uuid()) @db.Uuid
  action         AuditAction
  userId         String?       @map("user_id") @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  ipAddress      String?       @map("ip_address") @db.VarChar(64)
  userAgent      String?       @map("user_agent") @db.VarChar(512)
  metadata       Json?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([action, createdAt])
  @@map("audit_events")
}

model RateLimitBucket {
  keyHash     String   @id @map("key_hash") @db.Char(64)
  count       Int      @default(1)
  windowEndsAt DateTime @map("window_ends_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([windowEndsAt])
  @@map("rate_limit_buckets")
}

model SupplierSearchCache {
  id              String   @id @default(uuid()) @db.Uuid
  query           String   @db.VarChar(200)
  normalizedQuery String   @map("normalized_query") @db.VarChar(200)
  targetCountry   String   @map("target_country") @db.Char(2)
  quantity        Int
  source          String   @db.VarChar(200)
  resultsJson     Json     @map("results_json")
  createdAt       DateTime @default(now()) @map("created_at")
  expiresAt       DateTime @map("expires_at")

  @@unique([normalizedQuery, targetCountry, quantity])
  @@index([normalizedQuery, targetCountry, quantity, createdAt])
  @@index([expiresAt])
  @@map("supplier_search_cache")
}

model ImportProject {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  name           String         @db.VarChar(160)
  targetCountry  String         @map("target_country") @db.Char(2)
  quantity       Int
  targetMargin   Decimal        @map("target_margin") @db.Decimal(5, 2)
  status         ProjectStatus  @default(DRAFT)
  createdById    String         @map("created_by") @db.Uuid
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User           @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  files          UploadedFile[]
  offers         SupplierOffer[]
  costCalculations CostCalculation[]
  offerAssessments OfferAssessment[]
  projectDecisions ProjectDecision[]
  negotiationMessages NegotiationMessage[]
  activities      ProjectActivity[]
  outcomes        ProjectOutcome[]
  recommendationFeedback RecommendationFeedback[]
  completionHistory ProjectCompletionHistory[]
  completionStatus ProjectCompletionStatus @default(ACTIVE) @map("completion_status")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([organizationId, createdAt, id])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, completionStatus, createdAt])
  @@index([organizationId, targetCountry])
  @@map("import_projects")
}

model ProjectOutcome {
  id                 String                @id @default(uuid()) @db.Uuid
  organizationId     String                @map("organization_id") @db.Uuid
  projectId          String                @map("project_id") @db.Uuid
  outcome            ProjectOutcomeType
  decisionStatus     ProjectDecisionStatus? @map("decision_status")
  finalPrice         Decimal?              @map("final_price") @db.Decimal(18, 4)
  finalCurrency      String?               @map("final_currency") @db.Char(3)
  purchaseSuccessful Boolean?              @map("purchase_successful")
  comment            String?               @db.Text
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project            ImportProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt          DateTime              @default(now()) @map("created_at")

  @@index([organizationId, projectId, createdAt])
  @@index([organizationId, decisionStatus, outcome])
  @@map("project_outcomes")
}

model RecommendationFeedback {
  id                String                     @id @default(uuid()) @db.Uuid
  organizationId    String                     @map("organization_id") @db.Uuid
  projectId         String                     @map("project_id") @db.Uuid
  projectDecisionId String                     @map("project_decision_id") @db.Uuid
  vote              RecommendationFeedbackVote
  comment           String?                    @db.Text
  organization      Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           ImportProject              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectDecision   ProjectDecision            @relation(fields: [projectDecisionId], references: [id], onDelete: Cascade)
  createdAt         DateTime                   @default(now()) @map("created_at")

  @@index([organizationId, projectId, createdAt])
  @@index([projectDecisionId, createdAt])
  @@map("recommendation_feedback")
}

model ProjectCompletionHistory {
  id             String                  @id @default(uuid()) @db.Uuid
  organizationId String                  @map("organization_id") @db.Uuid
  projectId      String                  @map("project_id") @db.Uuid
  status         ProjectCompletionStatus
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        ImportProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt      DateTime                @default(now()) @map("created_at")

  @@index([organizationId, projectId, createdAt])
  @@map("project_completion_history")
}

model ProjectActivity {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  projectId      String              @map("project_id") @db.Uuid
  type           ProjectActivityType
  title          String              @db.VarChar(200)
  description    String?             @db.Text
  metadata       Json?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        ImportProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now()) @map("created_at")

  @@index([organizationId, projectId, createdAt])
  @@index([organizationId, projectId, type, createdAt])
  @@map("project_activities")
}

model UploadedFile {
  id               String               @id @default(uuid()) @db.Uuid
  organizationId   String               @map("organization_id") @db.Uuid
  projectId        String               @map("project_id") @db.Uuid
  linkedOfferId    String?              @map("linked_offer_id") @db.Uuid
  documentType     DocumentType         @default(OFFER) @map("document_type")
  originalFilename String               @map("original_filename") @db.VarChar(255)
  mimeType         String               @map("mime_type") @db.VarChar(120)
  size             BigInt
  checksum         String               @db.Char(64)
  storageKey       String               @unique @map("storage_key") @db.VarChar(1024)
  processingStatus FileProcessingStatus @default(QUEUED) @map("processing_status")
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project          ImportProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  linkedOffer      SupplierOffer?        @relation("VaultOfferDocuments", fields: [linkedOfferId], references: [id], onDelete: SetNull)
  jobs             ProcessingJob[]
  supplierOffer    SupplierOffer?
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  @@index([organizationId, projectId])
  @@index([organizationId, projectId, documentType])
  @@index([linkedOfferId, createdAt])
  @@index([processingStatus, createdAt])
  @@map("uploaded_files")
}

model ProcessingJob {
  id            String              @id @default(uuid()) @db.Uuid
  type          ProcessingJobType
  status        ProcessingJobStatus @default(PENDING)
  fileId        String?             @map("file_id") @db.Uuid
  payload       Json
  attempts      Int                 @default(0)
  maxAttempts   Int                 @default(5) @map("max_attempts")
  availableAt   DateTime            @default(now()) @map("available_at")
  lockedAt      DateTime?           @map("locked_at")
  lastError     String?             @map("last_error") @db.Text
  deadLetteredAt DateTime?          @map("dead_lettered_at")
  file          UploadedFile?       @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([status, availableAt])
  @@index([fileId])
  @@map("processing_jobs")
}

model SupplierOffer {
  id                  String                @id @default(uuid()) @db.Uuid
  organizationId      String                @map("organization_id") @db.Uuid
  projectId           String                @map("project_id") @db.Uuid
  fileId              String?               @unique @map("file_id") @db.Uuid
  supplierName        String                @map("supplier_name") @db.VarChar(200)
  supplierCountry     String?               @map("supplier_country") @db.Char(2)
  contactEmail        String?               @map("contact_email") @db.VarChar(320)
  contactPhone        String?               @map("contact_phone") @db.VarChar(60)
  moq                 Int?
  unitPrice           Decimal?              @map("unit_price") @db.Decimal(18, 4)
  currency            String?               @db.Char(3)
  incoterm            String?               @db.VarChar(20)
  deliveryTimeDays    Int?                  @map("delivery_time_days")
  paymentTerms        String?               @map("payment_terms") @db.VarChar(500)
  warranty            String?               @db.VarChar(500)
  rawExtractedText    String?               @map("raw_extracted_text") @db.Text
  extractionStatus    OfferExtractionStatus @default(PENDING) @map("extraction_status")
  confidenceScore     Decimal?              @map("confidence_score") @db.Decimal(4, 3)
  supplierVerified    Boolean?              @map("supplier_verified")
  yearsOnPlatform     Int?                  @map("years_on_platform")
  responseRatePercent Decimal?              @map("response_rate_percent") @db.Decimal(5, 2)
  transactionCount    Int?                  @map("transaction_count")
  employeeCount       Int?                  @map("employee_count")
  profileCompletenessScore Int?             @map("profile_completeness_score")
  sampleAvailable     Boolean?              @map("sample_available")
  termsClarityScore   Int?                  @map("terms_clarity_score")
  shippingClarityScore Int?                 @map("shipping_clarity_score")
  source              SupplierOfferSource   @default(MANUAL)
  sourceMetadata      Json?                 @map("source_metadata")
  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project             ImportProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file                UploadedFile?          @relation(fields: [fileId], references: [id], onDelete: SetNull)
  vaultDocuments      UploadedFile[]         @relation("VaultOfferDocuments")
  costCalculations    CostCalculation[]
  assessments         OfferAssessment[]
  selectedInDecisions ProjectDecision[] @relation("SelectedOffer")
  negotiationMessages NegotiationMessage[]
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  @@index([organizationId, projectId])
  @@index([projectId, extractionStatus])
  @@map("supplier_offers")
}

enum SupplierOfferSource {
  MANUAL
  FILE_EXTRACTION
  SEARCH_RESULT
}

model CostCalculation {
  id                  String            @id @default(uuid()) @db.Uuid
  organizationId      String            @map("organization_id") @db.Uuid
  projectId           String            @map("project_id") @db.Uuid
  offerId             String            @map("offer_id") @db.Uuid
  targetCountry       String            @map("target_country") @db.Char(2)
  quantity            Int
  unitPrice           Decimal           @map("unit_price") @db.Decimal(18, 4)
  currency            String            @db.Char(3)
  incoterm            String            @db.VarChar(20)
  shippingCost        Decimal           @map("shipping_cost") @db.Decimal(18, 2)
  customsDutyRate     Decimal           @map("customs_duty_rate") @db.Decimal(7, 4)
  customsDutyAmount   Decimal           @map("customs_duty_amount") @db.Decimal(18, 2)
  vatRate             Decimal           @map("vat_rate") @db.Decimal(7, 4)
  vatAmount           Decimal           @map("vat_amount") @db.Decimal(18, 2)
  storageCost         Decimal           @map("storage_cost") @db.Decimal(18, 2)
  inspectionCost      Decimal           @map("inspection_cost") @db.Decimal(18, 2)
  otherCosts          Decimal           @map("other_costs") @db.Decimal(18, 2)
  landedCostTotal     Decimal           @map("landed_cost_total") @db.Decimal(18, 2)
  landedCostPerUnit   Decimal           @map("landed_cost_per_unit") @db.Decimal(18, 2)
  targetSellingPrice  Decimal           @map("target_selling_price") @db.Decimal(18, 2)
  grossMarginPercent  Decimal           @map("gross_margin_percent") @db.Decimal(8, 4)
  breakEvenPrice      Decimal           @map("break_even_price") @db.Decimal(18, 2)
  calculationStatus   CalculationStatus @default(DRAFT) @map("calculation_status")
  organization        Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project             ImportProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  offer               SupplierOffer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  assessments         OfferAssessment[]
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@index([organizationId, projectId])
  @@index([offerId, createdAt])
  @@map("cost_calculations")
}

model OfferAssessment {
  id                  String               @id @default(uuid()) @db.Uuid
  organizationId      String               @map("organization_id") @db.Uuid
  projectId           String               @map("project_id") @db.Uuid
  offerId             String               @map("offer_id") @db.Uuid
  costCalculationId   String?              @map("cost_calculation_id") @db.Uuid
  supplierRiskScore   Int                  @map("supplier_risk_score")
  offerQualityScore   Int                  @map("offer_quality_score")
  overallScore        Int                  @map("overall_score")
  confidenceScore     Decimal              @map("confidence_score") @db.Decimal(5, 2)
  recommendationStatus RecommendationStatus @map("recommendation_status")
  explanation         String               @db.Text
  scoreBreakdown      Json                 @map("score_breakdown")
  assessmentVersion   String               @map("assessment_version") @db.VarChar(40)
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project             ImportProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  offer               SupplierOffer        @relation(fields: [offerId], references: [id], onDelete: Cascade)
  costCalculation     CostCalculation?      @relation(fields: [costCalculationId], references: [id], onDelete: SetNull)
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  @@index([organizationId, projectId])
  @@index([offerId, createdAt])
  @@map("offer_assessments")
}

model ProjectDecision {
  id                 String                @id @default(uuid()) @db.Uuid
  organizationId     String                @map("organization_id") @db.Uuid
  projectId          String                @map("project_id") @db.Uuid
  selectedOfferId    String?               @map("selected_offer_id") @db.Uuid
  status             ProjectDecisionStatus
  decisionReason     String                @map("decision_reason") @db.Text
  actionChecklist    Json                  @map("action_checklist")
  summarySnapshot    Json                  @map("summary_snapshot")
  decisionVersion    String                @map("decision_version") @db.VarChar(40)
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project            ImportProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  selectedOffer      SupplierOffer?         @relation("SelectedOffer", fields: [selectedOfferId], references: [id], onDelete: SetNull)
  negotiationMessages NegotiationMessage[]
  recommendationFeedback RecommendationFeedback[]
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  @@index([organizationId, projectId])
  @@index([projectId, createdAt])
  @@map("project_decisions")
}

model NegotiationMessage {
  id                String                   @id @default(uuid()) @db.Uuid
  organizationId    String                   @map("organization_id") @db.Uuid
  projectId         String                   @map("project_id") @db.Uuid
  offerId           String                   @map("offer_id") @db.Uuid
  projectDecisionId String                   @map("project_decision_id") @db.Uuid
  tone              NegotiationTone
  status            NegotiationMessageStatus @default(PROPOSED)
  requestTypes      NegotiationRequestType[] @map("request_types")
  lockedFacts       Json                     @map("locked_facts")
  subject           String                   @db.VarChar(300)
  body              String                   @db.Text
  sentAt            DateTime?                @map("sent_at")
  organization      Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           ImportProject            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  offer             SupplierOffer            @relation(fields: [offerId], references: [id], onDelete: Cascade)
  projectDecision   ProjectDecision           @relation(fields: [projectDecisionId], references: [id], onDelete: Cascade)
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  @@index([organizationId, projectId])
  @@index([projectId, createdAt])
  @@index([offerId, createdAt])
  @@map("negotiation_messages")
}
